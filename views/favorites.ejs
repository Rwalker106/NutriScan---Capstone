<div class="container" style="max-width: 800px; margin: 40px auto; padding: 20px; background: var(--color-background);">
    <h2 style="color: var(--color-primary-dark); font-size: 2rem; margin-bottom: 0.5rem;">Saved Scans</h2>
    <p style="color: var(--color-muted); margin-bottom: 2rem;">Your favorite and frequently visited products are stored right here in your browser.</p>
    
    <div id="favorites-container" style="display: flex; flex-direction: column; gap: 1rem;"></div>
    
    <div id="empty-state" style="display: none; background: var(--color-card); border-radius: 12px; padding: 3rem; text-align: center; border: 1px solid var(--color-border); box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
        <p style="color: var(--color-muted); font-size: 1.1rem; margin-bottom: 1.5rem;">You haven't saved any scans yet!</p>
        <a href="/" class="search-btn accent-btn" style="display: inline-flex; width: auto; text-decoration: none;">Scan a Product</a>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('favorites-container');
    const emptyState = document.getElementById('empty-state');
    
    const favs = JSON.parse(localStorage.getItem('saved_scans') || '{}');
    const keys = Object.keys(favs);
    
    if (keys.length === 0) {
        emptyState.style.display = 'block';
        return;
    }

    // Sort by most recently added
    keys.sort((a,b) => favs[b].date - favs[a].date).forEach(code => {
        const item = favs[code];
        
        const card = document.createElement('a');
        card.href = `/product/${code}`;
        card.style = 'display: flex; align-items: center; justify-content: space-between; padding: 1.25rem; border-radius: 12px; border: 1px solid var(--color-border); background: var(--color-card); text-decoration: none; color: inherit; box-shadow: 0 2px 8px rgba(0,0,0,0.03); transition: transform 0.2s';
        
        card.onmouseenter = () => card.style.transform = 'translateY(-2px)';
        card.onmouseleave = () => card.style.transform = 'translateY(0)';
        
        card.innerHTML = `
            <div style="display: flex; align-items: center; gap: 1.5rem; flex: 1;">
                <div style="width: 70px; height: 70px; background: #fff; border-radius: 8px; display: flex; align-items: center; justify-content: center; overflow: hidden; border: 1px solid #f1f5f9;">
                    <img src="${item.image}" alt="${item.name.replace(/"/g, '&quot;')}" style="max-width: 100%; max-height: 100%; object-fit: contain;" onerror="this.src='/img/no-image.png'">
                </div>
                <div>
                    <h3 style="margin: 0 0 0.25rem; font-size: 1.15rem; color: var(--color-text);">${item.name}</h3>
                    <p style="margin: 0; color: var(--color-muted); font-family: monospace; font-size: 0.9rem;">${code}</p>
                </div>
            </div>
            <button class="remove-btn" data-code="${code}" title="Remove from Saved" style="background: none; border: none; color: #ef4444; cursor: pointer; font-size: 1.5rem; padding: 10px; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; border-radius: 50%; transition: background 0.2s;">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </button>
        `;
        
        container.appendChild(card);
    });

    // Handle remove buttons purely through DOM trapping
    document.querySelectorAll('.remove-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault(); // Stop the event from propagating to the enclosing <a> tag
            e.stopPropagation();
            
            const code = btn.getAttribute('data-code');
            delete favs[code];
            localStorage.setItem('saved_scans', JSON.stringify(favs));
            
            const parentCard = btn.closest('a');
            parentCard.style.opacity = '0';
            setTimeout(() => {
                parentCard.remove();
                if(Object.keys(favs).length === 0) emptyState.style.display = 'block';
            }, 300);
        });
        
        btn.onmouseenter = () => btn.style.background = '#fee2e2';
        btn.onmouseleave = () => btn.style.background = 'transparent';
    });
});
</script>
